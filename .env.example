# ═══════════════════════════════════════════════════════════════
# Configuration — SAV Assistant (monorepo)
# cp .env.example .env  puis adapter les valeurs
# ═══════════════════════════════════════════════════════════════

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=sav_user
POSTGRES_PASSWORD=sav_password
POSTGRES_DB=sav_db
POSTGRES_PORT=5432

# ─── API existante (factures/articles) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sav_db
DB_USER=sav_user
DB_PASSWORD=sav_password
API_PORT=3000

# ─── n8n ───────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678
N8N_USER=admin
N8N_PASSWORD=changeme
N8N_ENCRYPTION_KEY=change-this-32-char-secret-key-!!

# ─── Backend SAV (nouveau, port 3001) ─────────────────────────
PORT=3001
JWT_SECRET=replace_with_a_strong_secret_min32chars
JWT_EXPIRES_IN=8h

# ─── Ollama ────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
N8N_MAX_CONCURRENCY=10
N8N_EXECUTIONS_DATA_MAX_AGE=720
