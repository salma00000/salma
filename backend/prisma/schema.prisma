generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Advisor {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String      @unique
  password_hash String
  full_name     String
  created_at    DateTime    @default(now()) @db.Timestamp(6)
  sessions      SavSession[]
  folders       SavFolder[]

  @@map("advisors")
}

model Customer {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  external_id  String?   @unique @db.VarChar(30)
  name         String    @db.VarChar(150)
  email        String?   @db.VarChar(200)
  phone        String?   @db.VarChar(30)
  loyalty_tier String?   @db.VarChar(20)
  organization String?   @db.VarChar(50)
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @default(now()) @db.Timestamp(6)
  invoices     Invoice[]
  folders      SavFolder[]

  @@map("customers")
}

model Invoice {
  id             Int           @id @default(autoincrement())
  invoice_number String        @unique @db.VarChar(30)
  customer_id    String?       @db.Uuid
  date           DateTime      @default(now()) @db.Timestamp(6)
  store          String?       @db.VarChar(150)
  amount_ht      Decimal       @default(0) @db.Decimal(12, 2)
  vat_rate       Decimal       @default(21) @db.Decimal(5, 2)
  /// Generated always as ROUND(amount_ht * (1 + vat_rate / 100), 2)
  amount_ttc     Decimal       @db.Decimal(12, 2)
  status         String?       @default("pending") @db.VarChar(30)
  source         String?       @default("local") @db.VarChar(50)
  created_at     DateTime      @default(now()) @db.Timestamp(6)
  updated_at     DateTime      @default(now()) @db.Timestamp(6)
  customer       Customer?     @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  lines          InvoiceLine[]
  folders        SavFolder[]

  @@map("invoices")
}

model InvoiceLine {
  id              Int       @id @default(autoincrement())
  invoice_id      Int
  label           String    @db.VarChar(200)
  description     String?
  quantity        Decimal   @default(1) @db.Decimal(10, 3)
  unit_price      Decimal   @db.Decimal(12, 2)
  /// Generated always as ROUND(quantity * unit_price, 2)
  subtotal        Decimal   @db.Decimal(14, 2)
  sku             String?   @db.VarChar(100)
  brand           String?   @db.VarChar(100)
  category        String?   @db.VarChar(100)
  warranty_months Int?
  product_state   String?   @db.VarChar(50)
  image_url       String?   @db.VarChar(500)
  supplier        String?   @db.VarChar(150)
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  invoice         Invoice   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  folders         SavFolder[]

  @@map("invoice_lines")
}

model ConfigValue {
  config_code String @db.VarChar(100)
  value_code  String @db.VarChar(100)
  label_fr    String? @db.VarChar(200)
  label_en    String? @db.VarChar(200)
  sort_order  Int    @default(0)

  @@id([config_code, value_code])
  @@map("config_values")
}

model SavFolder {
  id                Int          @id @default(autoincrement())
  folder_reference  String       @unique @db.VarChar(30)
  customer_id       String?      @db.Uuid
  invoice_id        Int?
  invoice_number    String?      @db.VarChar(30)
  product_id        Int?
  issue_type        String?      @db.VarChar(100)
  issue_description String
  product_state     String?      @db.VarChar(50)
  status            String       @default("open") @db.VarChar(20)
  priority          String       @default("medium") @db.VarChar(10)
  advisor_id        String?      @db.Uuid
  ai_summary        String?
  created_at        DateTime     @default(now()) @db.Timestamp(6)
  updated_at        DateTime     @default(now()) @db.Timestamp(6)
  customer          Customer?    @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  invoice           Invoice?     @relation(fields: [invoice_id], references: [id], onDelete: SetNull)
  product           InvoiceLine? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  advisor           Advisor?     @relation(fields: [advisor_id], references: [id], onDelete: SetNull)

  @@map("sav_folders")
}

model SavSession {
  session_id String       @id
  draft      Json?
  turn       Int          @default(0)
  advisor_id String?      @db.Uuid
  updated_at DateTime     @default(now()) @db.Timestamp(6)
  advisor    Advisor?     @relation(fields: [advisor_id], references: [id])
  messages   SavMessage[]

  @@map("sav_sessions")
}

model SavMessage {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id String
  role       String
  content    String
  created_at DateTime   @default(now()) @db.Timestamp(6)
  session    SavSession @relation(fields: [session_id], references: [session_id], onDelete: Cascade)

  @@map("sav_messages")
}
